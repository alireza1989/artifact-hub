# Artifact Hub — environment configuration.
# Copy to `.env.local` and fill in real values. Never commit real secrets.
# All variables are validated at boot by src/lib/env.ts (fail-fast on missing/invalid).

# Neon Postgres connection string in prod. For local dev this matches the
# docker-compose service (docker compose up -d).
DATABASE_URL=postgres://artifact_hub:artifact_hub@localhost:5432/artifact_hub

# Vercel Blob read/write token (artifact binaries).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me

# Anthropic API key (Claude Haiku for metadata + feedback synthesis).
ANTHROPIC_API_KEY=sk-ant-replace-me

# 32+ random bytes; signs share-link tokens (HMAC-SHA256). e.g. `openssl rand -base64 48`
SHARE_LINK_SECRET=replace-with-32-plus-random-bytes

# Bearer token for write operations (REST/MCP) and the web UI token-gate.
ADMIN_API_TOKEN=replace-with-strong-random-token

# Absolute base URL used to build share links (no trailing slash).
APP_BASE_URL=http://localhost:3000

# Per-feature daily LLM call budget (guardrail against runaway spend).
AI_DAILY_CALL_BUDGET=500
